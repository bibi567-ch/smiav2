# .env.example — SMIA GAMLP
# Copiar como .env y completar los valores realeclear
s

# ── Base de datos ────────────────────────────────────────────────────
DB_NAME=smia_db
DB_USER=smia_user
DB_PASSWORD=CAMBIAR_EN_PRODUCCION
DATABASE_URL=postgis://smia_user:CAMBIAR_EN_PRODUCCION@db:5432/smia_db

# ── Django ───────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=CAMBIAR_EN_PRODUCCION_clave_larga_y_aleatoria
DJANGO_DEBUG=True                    # False en producción
ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS (Angular dev server) ────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ── Redis / Celery ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── SIGIR (Ministerio MMAyA) ─────────────────────────────────────────
SIGIR_API_URL=https://sigir.mmaya.gob.bo/api/v1
SIGIR_API_KEY=OBTENER_DEL_MMAYA
SIGIR_RETRY_DELAY_SECONDS=1800       # 30 minutos (HU-09.1)

# ── Email (notificaciones HU-13.1) ───────────────────────────────────
EMAIL_HOST=smtp.gamlp.bo
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=smia@gamlp.bo
EMAIL_HOST_PASSWORD=CAMBIAR_EN_PRODUCCION